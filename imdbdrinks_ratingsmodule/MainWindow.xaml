<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="imdbdrinks_ratingsmodule.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:domain="using:imdbdrinks_ratingsmodule.Domain"
    mc:Ignorable="d"
    Title="IMDbDrinks - Ratings Module">
    
    <Grid Background="#F5F5F5" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" 
                  Text="Ratings and Reviews for Product 100" 
                  FontSize="24"
                  FontWeight="SemiBold"
                  FontFamily="{StaticResource FontFamily}"
                  Foreground="#333333"
                  Margin="0,0,0,16"/>
        
        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="0,16,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Column: Ratings List -->
            <Border Grid.Column="0" 
                   Background="#FFFFFF"
                   BorderBrush="#E0E0E0"
                   BorderThickness="1"
                   CornerRadius="4"
                   Padding="16"
                   Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="Ratings"
                              FontFamily="{StaticResource FontFamily}"
                              FontSize="20"
                              FontWeight="SemiBold"
                              Foreground="#333333"
                              Margin="0,0,0,8"/>
                    
                    <ListView Grid.Row="1"
                             Margin="0,8,0,0"
                             ItemsSource="{x:Bind RatingViewModel.Ratings, Mode=TwoWay}"
                             SelectionMode="Single"
                             SelectionChanged="RatingSelection_Changed"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="Margin" Value="0,4"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="domain:Rating">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Image Source="/Assets/FullBottle.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                        <TextBlock Text="{x:Bind RatingValue}" 
                                                 FontWeight="Bold" 
                                                 FontSize="16" 
                                                 VerticalAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="by User " 
                                                 FontFamily="{StaticResource FontFamily}"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Foreground="#666666"/>
                                        <TextBlock Text="{x:Bind UserId}" 
                                                 FontFamily="{StaticResource FontFamily}"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Foreground="#666666"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
            
            <!-- Right Column: Statistics -->
            <Border Grid.Column="1" 
                   Background="#FFFFFF"
                   BorderBrush="#E0E0E0"
                   BorderThickness="1"
                   CornerRadius="4"
                   Padding="16"
                   Margin="12,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="Statistics" 
                              FontFamily="{StaticResource FontFamily}"
                              FontSize="20"
                              FontWeight="SemiBold"
                              Foreground="#333333"
                              Margin="0,0,0,8"/>
                    
                    <!-- Average Rating Panel -->
                    <Border Grid.Row="1" 
                           Background="#F0F7FF" 
                           CornerRadius="4" 
                           Padding="16" 
                           Margin="0,16,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Image Grid.Column="0" 
                                  Source="/Assets/FullBottle.png" 
                                  Width="32" 
                                  Height="32" 
                                  Margin="0,0,16,0"/>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Average Rating" 
                                         FontWeight="SemiBold" 
                                         FontFamily="{StaticResource FontFamily}"
                                         Margin="0,0,0,4"/>
                                
                                <TextBlock Text="{x:Bind RatingViewModel.AverageRating, Mode=OneWay}" 
                                         FontSize="28" 
                                         FontWeight="Bold"
                                         FontFamily="{StaticResource FontFamily}"
                                         Foreground="#0078D7"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Add Rating Panel -->
                    <Border Grid.Row="2" 
                           Background="#F5F5F5" 
                           CornerRadius="4" 
                           Padding="16" 
                           Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Image Grid.Column="0" 
                                  Source="/Assets/Bottle.png" 
                                  Width="32" 
                                  Height="32" 
                                  Margin="0,0,16,0"/>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Your Rating" 
                                         FontWeight="SemiBold"
                                         FontFamily="{StaticResource FontFamily}"
                                         Margin="0,0,0,8"/>
                                
                                <Button Content="Add Rating" 
                                       Click="AddRating_Click" 
                                       Background="#0078D7"
                                       Foreground="White"
                                       FontFamily="{StaticResource FontFamily}"
                                       FontWeight="SemiBold"
                                       Padding="16,8"
                                       BorderThickness="0"
                                       CornerRadius="4"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Reviews Section -->
        <Border Grid.Row="2" 
               Background="#FFFFFF"
               BorderBrush="#E0E0E0"
               BorderThickness="1"
               CornerRadius="4"
               Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Reviews Header -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" 
                              Text="Reviews" 
                              FontFamily="{StaticResource FontFamily}"
                              FontSize="20"
                              FontWeight="SemiBold"
                              Foreground="#333333"
                              Margin="0,0,0,8"/>
                    
                    <Button Grid.Column="1" 
                           Content="Add Review" 
                           Click="AddReview_Click" 
                           Background="#0078D7"
                           Foreground="White"
                           FontFamily="{StaticResource FontFamily}"
                           FontWeight="SemiBold"
                           Padding="16,8"
                           BorderThickness="0"
                           CornerRadius="4"/>
                </Grid>
                
                <!-- Reviews List -->
                <ListView Grid.Row="1" 
                         ItemsSource="{x:Bind ReviewViewModel.Reviews, Mode=OneWay}"
                         SelectedItem="{x:Bind ReviewViewModel.SelectedReview, Mode=TwoWay}" 
                         Background="Transparent"
                         BorderThickness="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Margin" Value="0,4"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="domain:Review">
                            <Border Background="White" 
                                   CornerRadius="4" 
                                   Padding="16" 
                                   BorderThickness="1" 
                                   BorderBrush="#E0E0E0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" 
                                             Text="{x:Bind Content}" 
                                             TextWrapping="Wrap" 
                                             FontFamily="{StaticResource FontFamily}"
                                             FontSize="14"
                                             Foreground="#333333"
                                             Margin="0,0,0,8"/>
                                    
                                    <TextBlock Grid.Row="1" 
                                             Text="{x:Bind CreationDate}" 
                                             FontFamily="{StaticResource FontFamily}"
                                             FontSize="12" 
                                             Foreground="#666666"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
        
        <!-- ContentDialog for no rating selected -->
        <ContentDialog x:Name="NoRatingSelectedDialog"
                      Title="No Rating Selected"
                      Content="Please select a rating before adding a review."
                      CloseButtonText="OK" />
    </Grid>
</Window>
