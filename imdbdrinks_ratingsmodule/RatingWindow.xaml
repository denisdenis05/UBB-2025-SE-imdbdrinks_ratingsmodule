<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="imdbdrinks_ratingsmodule.RatingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:imdbdrinks_ratingsmodule"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#F5F5F5">
        <Border 
            Background="White" 
            CornerRadius="8" 
            Width="400" 
            Margin="24"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            HorizontalAlignment="Center" 
            VerticalAlignment="Center">
            
            <StackPanel Padding="32">
                <!-- Header -->
                <TextBlock 
                    Text="Rate this" 
                    FontSize="24" 
                    FontWeight="SemiBold" 
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource FontFamily}"
                    Foreground="#333333"/>
                    
                <TextBlock 
                    Text="Drink name" 
                    FontSize="20" 
                    FontWeight="SemiBold" 
                    HorizontalAlignment="Center" 
                    Margin="0,4,0,32"
                    FontFamily="{StaticResource FontFamily}"
                    Foreground="#666666"/>

                <!-- Bottle Rating -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
                    <!-- Bottle 1 -->
                    <StackPanel>
                        <Image x:Name="Bottle1Empty" Source="ms-appx:///Assets/Bottle.png" Width="40" Height="80"/>
                        <Image x:Name="Bottle1Full" Source="ms-appx:///Assets/FullBottle.png" Width="40" Height="80" 
                               Visibility="Collapsed" Margin="0,-80,0,0"/>
                        <Rectangle Fill="Transparent" Width="40" Height="80" Margin="0,-80,0,0" 
                                   Tapped="Bottle1_Click"/>
                        <TextBlock Text="1" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                    
                    <!-- Bottle 2 -->
                    <StackPanel>
                        <Image x:Name="Bottle2Empty" Source="ms-appx:///Assets/Bottle.png" Width="40" Height="80"/>
                        <Image x:Name="Bottle2Full" Source="ms-appx:///Assets/FullBottle.png" Width="40" Height="80" 
                               Visibility="Collapsed" Margin="0,-80,0,0"/>
                        <Rectangle Fill="Transparent" Width="40" Height="80" Margin="0,-80,0,0" 
                                   Tapped="Bottle2_Click"/>
                        <TextBlock Text="2" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                    
                    <!-- Bottle 3 -->
                    <StackPanel>
                        <Image x:Name="Bottle3Empty" Source="ms-appx:///Assets/Bottle.png" Width="40" Height="80"/>
                        <Image x:Name="Bottle3Full" Source="ms-appx:///Assets/FullBottle.png" Width="40" Height="80" 
                               Visibility="Collapsed" Margin="0,-80,0,0"/>
                        <Rectangle Fill="Transparent" Width="40" Height="80" Margin="0,-80,0,0" 
                                   Tapped="Bottle3_Click"/>
                        <TextBlock Text="3" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                    
                    <!-- Bottle 4 -->
                    <StackPanel>
                        <Image x:Name="Bottle4Empty" Source="ms-appx:///Assets/Bottle.png" Width="40" Height="80"/>
                        <Image x:Name="Bottle4Full" Source="ms-appx:///Assets/FullBottle.png" Width="40" Height="80" 
                               Visibility="Collapsed" Margin="0,-80,0,0"/>
                        <Rectangle Fill="Transparent" Width="40" Height="80" Margin="0,-80,0,0" 
                                   Tapped="Bottle4_Click"/>
                        <TextBlock Text="4" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                    
                    <!-- Bottle 5 -->
                    <StackPanel>
                        <Image x:Name="Bottle5Empty" Source="ms-appx:///Assets/Bottle.png" Width="40" Height="80"/>
                        <Image x:Name="Bottle5Full" Source="ms-appx:///Assets/FullBottle.png" Width="40" Height="80" 
                               Visibility="Collapsed" Margin="0,-80,0,0"/>
                        <Rectangle Fill="Transparent" Width="40" Height="80" Margin="0,-80,0,0" 
                                   Tapped="Bottle5_Click"/>
                        <TextBlock Text="5" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Rating Value Indicator -->
                <TextBlock x:Name="RatingTextBlock"
                    FontSize="16" 
                    FontWeight="SemiBold"
                    Foreground="#0078D7"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,28"
                    FontFamily="{StaticResource FontFamily}"
                    Visibility="Collapsed"/>

                <!-- Rate Button -->
                <Button 
                    Content="Rate" 
                    Background="#0078D7" 
                    Foreground="White" 
                    FontSize="16" 
                    FontWeight="SemiBold"
                    Padding="16,10"
                    HorizontalAlignment="Stretch"
                    BorderThickness="0"
                    CornerRadius="4" 
                    Click="RateButton_Click"
                    FontFamily="{StaticResource FontFamily}"/>
                    
                <Button 
                    Content="Cancel" 
                    Background="Transparent" 
                    Foreground="#666666" 
                    FontSize="14"
                    Margin="0,8,0,0"
                    Padding="16,8"
                    HorizontalAlignment="Center"
                    BorderThickness="0"
                    Click="CancelButton_Click"
                    FontFamily="{StaticResource FontFamily}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
